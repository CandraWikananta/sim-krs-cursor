# Dipakai saat `npm run build` (mode production).
# Ganti URL di bawah dengan URL HTTPS backend Anda di Render (tanpa slash di akhir).
#
# PENTING untuk deploy drag & drop: nilai ini disematkan ke bundle JS pada saat build.
# Setelah mengubah file ini, jalankan lagi `npm run build` sebelum mengunggah folder `out`.

NEXT_PUBLIC_API_URL=https://GANTI-DENGAN-URL-BACKEND-RENDER-ANDA.onrender.com
NEXT_PUBLIC_APP_NAME=Sistem KRS
NEXT_PUBLIC_APP_UNIVERSITY=Universitas Contoh
NEXT_PUBLIC_SEMESTER_AKTIF=2024/2025 Ganjil
