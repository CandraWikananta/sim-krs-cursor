# ============================================================
# FRONTEND NEXT.JS - Environment Variables
# Salin file ini menjadi .env.local untuk development
# Di Netlify, isi melalui Site Settings > Environment Variables
# ============================================================

# URL Backend Flask
# Development: http://localhost:5000
# Production: URL dari Render.com (contoh: https://sim-krs-backend.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Nama aplikasi (opsional, untuk display)
NEXT_PUBLIC_APP_NAME=Sistem KRS
NEXT_PUBLIC_APP_UNIVERSITY=Universitas Contoh

# Semester aktif (untuk display)
NEXT_PUBLIC_SEMESTER_AKTIF=2024/2025 Ganjil
