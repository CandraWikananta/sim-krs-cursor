# ============================================================
# BACKEND FLASK - Environment Variables
# Salin file ini menjadi .env dan isi dengan nilai yang benar
# ============================================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=ganti-dengan-random-string-yang-panjang-dan-aman

# JWT
JWT_SECRET_KEY=ganti-dengan-jwt-secret-yang-berbeda-dan-aman
JWT_ACCESS_TOKEN_EXPIRES=3600

# Supabase
# Dapatkan dari: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Upstash Redis
# Dapatkan dari: Upstash Console > Redis Database > REST API
UPSTASH_REDIS_REST_URL=https://xxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS — origin yang boleh memanggil API (harus persis: https + host, tanpa / di akhir).
# Production: https://nama-anda.netlify.app
# Beberapa origin (pisahkan koma): https://app.netlify.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Cache TTL (detik)
CACHE_TTL_MAHASISWA=300
CACHE_TTL_MATA_KULIAH=300
CACHE_TTL_DOSEN=300

# Semester aktif saat ini
SEMESTER_AKTIF=2024/2025 Ganjil
MAX_SKS_PER_SEMESTER=24
